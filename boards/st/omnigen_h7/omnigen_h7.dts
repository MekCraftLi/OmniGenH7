/dts-v1/;

#include <st/h7/stm32h723Xg.dtsi>
#include <st/h7/stm32h723zgtx-pinctrl.dtsi>

/ {
    model = "OmniGen H7 Board";
    compatible = "mekcraft,omnigen-h7";

    chosen {
      zephyr,console = &usart3;
      zephyr,shell-uart = &usart3;
      zephyr,sram = &sram0;
      zephyr,flash = &flash0;
    };

    leds {
      compatible = "gpio-leds";
      user_led: led_0 {
        gpios = <&gpiog 7 GPIO_ACTIVE_HIGH>;
        label = "User LED";
      };
    };

    aliases {
      led0 = &user_led;
    };
};

&usart3 {
  pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
  pinctrl-names = "default";
  current-speed = <115200>;
  status = "okay";
};

&clk_lse {
  status = "okay";
};

&clk_hse {
  clock-frequency = <DT_FREQ_M(25)>;
  status = "okay";
};

&pll {
  div-m = <5>;
  mul-n = <110>;
  div-p = <2>;
  div-q = <2>;
  div-r = <2>;
  clocks = <&clk_hse>;
  status = "okay";
};

&pwr {
  power-supply = "ldo";
};

&rcc {
  clocks = <&pll>;
  clock-frequency = <DT_FREQ_M(550)>;
  d1cpre = <1>;
  hpre = <2>;
  d1ppre = <2>;
  d2ppre1 = <2>;
  d2ppre2 = <2>;
  d3ppre = <2>;
};


